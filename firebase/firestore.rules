rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(roomId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/rooms/$(roomId)).data.ownerId == request.auth.uid;
    }
    function hasShowControl(roomId) {
      return get(/databases/$(database)/documents/rooms/$(roomId)).data.features.showControl == true;
    }

    match /rooms/{roomId} {
      // Viewer is public (share-by-roomId); controller writes are owner-only.
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn()
        && request.auth.uid == resource.data.ownerId
        && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isSignedIn()
        && request.auth.uid == resource.data.ownerId;

      match /timers/{timerId} {
        // Public read for viewers; owner-only writes.
        allow read: if true;
        allow create, update, delete: if isOwner(roomId);
      }

      // Live cues (Show Control tier+ only)
      match /liveCues/{cueId} {
        // Keep read authenticated-only for now; cue metadata can include slide notes / paths.
        allow read: if isSignedIn() && hasShowControl(roomId);
        allow create, update, delete: if isOwner(roomId) && hasShowControl(roomId);
      }

      // Room state (v2): /rooms/{roomId}/state/current
      match /state/current {
        allow read: if true;
        allow create, update, delete: if isOwner(roomId);
      }

      // Migration backups (v1 -> v2 rollback support)
      match /migrationBackups/{backupId} {
        allow read, write: if isOwner(roomId);
      }
    }
  }
}
