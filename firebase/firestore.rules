rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(roomId) {
      return request.auth != null
        && get(/databases/$(database)/documents/rooms/$(roomId)).data.ownerId == request.auth.uid;
    }
    function hasShowControl(roomId) {
      return get(/databases/$(database)/documents/rooms/$(roomId)).data.features.showControl == true;
    }

    match /rooms/{roomId} {
      // Viewer is public; controller writes are owner-only.
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;
      allow update: if request.auth != null
        && request.auth.uid == resource.data.ownerId
        && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.ownerId;

      match /timers/{timerId} {
        allow read: if true;
        allow create, update, delete: if request.auth != null
          && get(/databases/$(database)/documents/rooms/$(roomId)).data.ownerId == request.auth.uid;
      }

      // Live cues (Show Control tier+ only)
      match /liveCues/{cueId} {
        allow read: if request.auth != null && hasShowControl(roomId);
        allow create, update, delete: if request.auth != null && isOwner(roomId) && hasShowControl(roomId);
      }

      // Room state (v2): /rooms/{roomId}/state/current
      match /state/{docId} {
        allow read: if true;
        allow write: if isOwner(roomId);
      }

      // Migration backups (v1 -> v2 rollback support)
      match /migrationBackups/{backupId} {
        allow read, write: if isOwner(roomId);
      }
    }
  }
}
