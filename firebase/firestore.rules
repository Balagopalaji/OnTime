rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isServiceAccount() {
      return isSignedIn()
        && request.auth.token.firebase.sign_in_provider == 'custom'
        && request.auth.token.service_account == true;
    }
    function isOwner(roomId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/rooms/$(roomId)).data.ownerId == request.auth.uid;
    }
    function hasShowControl(roomId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/rooms/$(roomId)).data.features.showControl == true;
    }
    function hasShowControlTier(roomId) {
      return get(/databases/$(database)/documents/rooms/$(roomId)).data.features.showControl == true;
    }
    function isBlocked(roomId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/rooms/$(roomId)/blocked/$(request.auth.uid));
    }
    function isOperator(roomId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/rooms/$(roomId)/operators/$(request.auth.uid));
    }
    function operatorRole(roomId) {
      return get(/databases/$(database)/documents/rooms/$(roomId)/operators/$(request.auth.uid)).data.odRole;
    }
    function operatorRoleMatches(roomId) {
      return isOperator(roomId)
        && request.resource.data.role == operatorRole(roomId);
    }
    function operatorRoleMatchesExisting(roomId) {
      return isOperator(roomId)
        && resource.data.role == operatorRole(roomId);
    }
    function isLockHolderByUserId(roomId) {
      return !exists(/databases/$(database)/documents/rooms/$(roomId)/lock/current)
        || get(/databases/$(database)/documents/rooms/$(roomId)/lock/current).data.userId == request.auth.uid;
    }

    // Tombstones for deleted rooms (TTL on expiresAt)
    match /deleted_rooms/{roomId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /rooms/{roomId} {
      // Viewer is public (share-by-roomId); controller writes are owner-only.
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn()
        && request.auth.uid == resource.data.ownerId
        && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isSignedIn()
        && request.auth.uid == resource.data.ownerId;

      match /timers/{timerId} {
        // Public read for viewers; owner-only writes.
        allow read: if true;
        allow create, update, delete: if isSignedIn() && isLockHolderByUserId(roomId);
      }

      // Phase 3: Sections and segments (Show Planner)
      match /sections/{sectionId} {
        allow read: if isSignedIn() && hasShowControlTier(roomId);
        allow create, update, delete: if isOwner(roomId);
      }

      match /segments/{segmentId} {
        allow read: if isSignedIn() && hasShowControlTier(roomId);
        allow create, update, delete: if isOwner(roomId);
      }

      // Phase 3: Manual cues (Show Planner)
      match /cues/{cueId} {
        allow read: if isSignedIn() && hasShowControlTier(roomId);
        allow create: if isSignedIn()
          && !isBlocked(roomId)
          && (isOwner(roomId) || operatorRoleMatches(roomId));
        allow update: if isSignedIn()
          && !isBlocked(roomId)
          && (
            isOwner(roomId)
            || (
              operatorRoleMatchesExisting(roomId)
              && request.resource.data.role == resource.data.role
            )
          );
        allow delete: if isSignedIn()
          && !isBlocked(roomId)
          && (isOwner(roomId) || operatorRoleMatchesExisting(roomId));
      }

      // Phase 3: Crew chat
      match /crewChat/{messageId} {
        allow read: if isSignedIn()
          && hasShowControlTier(roomId)
          && (isOwner(roomId) || isOperator(roomId));
        allow create: if isSignedIn()
          && hasShowControlTier(roomId)
          && !isBlocked(roomId)
          && (isOwner(roomId) || isOperator(roomId));
        allow update, delete: if isSignedIn()
          && hasShowControlTier(roomId)
          && !isBlocked(roomId)
          && (isOwner(roomId) || resource.data.senderId == request.auth.uid);
      }

      // Live cues (Show Control tier+ only)
      match /liveCues/{cueId} {
        // Keep read authenticated-only for now; cue metadata can include slide notes / paths.
        allow read: if hasShowControl(roomId);
        allow create, update, delete: if hasShowControl(roomId)
          && (isLockHolderByUserId(roomId) || isServiceAccount());
      }

      // Room state (v2): /rooms/{roomId}/state/current
      match /state/current {
        allow read: if true;
        allow create, update, delete: if isSignedIn() && isLockHolderByUserId(roomId);
      }

      // Migration backups (v1 -> v2 rollback support)
      match /migrationBackups/{backupId} {
        allow read, write: if isOwner(roomId);
      }

      match /lock/{lockId} {
        allow read: if true;
        allow write: if false;
      }

      match /config/pin {
        allow read: if isSignedIn();
        allow create, update, delete: if isOwner(roomId);
      }

      match /config/invite {
        allow read: if isOwner(roomId);
        allow create, update, delete: if isOwner(roomId);
      }

      match /operators/{odUserId} {
        allow read: if isOwner(roomId) || (isSignedIn() && request.auth.uid == odUserId);
        allow create: if isOwner(roomId);
        allow update: if isOwner(roomId) || (isSignedIn() && request.auth.uid == odUserId);
        allow delete: if isOwner(roomId);
      }

      match /blocked/{odUserId} {
        allow read: if isOwner(roomId) || (isSignedIn() && request.auth.uid == odUserId);
        allow create, update, delete: if isOwner(roomId);
      }

      match /controlRequest/{requestId} {
        allow read: if isSignedIn();
        allow write: if false;
      }

      match /clients/{clientId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && request.resource.data.clientId == clientId
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.clientType == 'controller';
        allow update: if isSignedIn()
          && request.resource.data.clientId == clientId
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.clientType == 'controller'
          && resource.data.userId == request.auth.uid
          && resource.data.clientId == clientId;
        allow delete: if isSignedIn()
          && resource.data.userId == request.auth.uid
          && resource.data.clientId == clientId;
      }
    }
  }
}
