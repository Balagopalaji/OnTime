rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Require any authenticated user; tighten to owner-only later if desired.
    match /rooms/{roomId} {
      allow read, create, update, delete: if request.auth != null;

      match /timers/{timerId} {
        allow read, create, update, delete: if request.auth != null;
      }
    }
  }
}
