{
  "name": "ontime-companion",
  "version": "0.1.1-dev.2",
  "description": "OnTime Companion desktop app (Electron, local mode bridge)",
  "private": true,
  "type": "commonjs",
  "main": "dist/main.js",
  "scripts": {
    "dev": "electron ./electron-dev.js",
    "build": "tsc -p tsconfig.json",
    "dist": "npm run build && electron-builder",
    "postdist": "node ./scripts/dev-sign-mac.js",
    "sign:installed": "node ./scripts/dev-sign-installed.js",
    "dist:dev": "npm version prerelease --preid dev --no-git-tag-version && npm run dist",
    "fetch-ffprobe": "node ./scripts/fetch-ffprobe.js",
    "lint": "echo \"No lint configured\""
  },
  "build": {
    "appId": "com.ontime.companion",
    "productName": "OnTime Companion",
    "directories": {
      "output": "dist_out"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "gatekeeperAssess": false,
      "identity": null
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "perMachine": false
    },
    "linux": {
      "target": "AppImage"
    },
    "extraResources": [
      {
        "from": "bin",
        "to": "bin",
        "filter": [
          "ffprobe",
          "ffprobe.exe",
          "ppt-probe.exe",
          "ppt-probe-mac"
        ]
      }
    ]
  },
  "dependencies": {
    "selfsigned": "^2.4.1",
    "jsonwebtoken": "^9.0.2",
    "node-machine-id": "^1.1.12",
    "socket.io": "^4.7.5"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/jsonwebtoken": "^9.0.7",
    "electron": "^31.7.4",
    "electron-builder": "^24.13.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  },
  "author": "OnTime Team"
}
